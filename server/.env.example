# Copy to project-root .env and fill in. NEVER commit the real .env.

# ── AI ──
OPENAI_API_KEY=            # chatbot (existing)
ANTHROPIC_API_KEY=         # CV tailoring
ANTHROPIC_MODEL=claude-sonnet-5   # or claude-opus-4-8
ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
ANTHROPIC_VERSION=2023-06-01

# ── Job sources ──
JOOBLE_API_KEY=            # https://jooble.org/api/about  (Remotive & Arbeitnow need no key)

# ── Pipeline tuning (all optional) ──
JOB_QUERIES=full stack developer,react developer,devops engineer,node.js developer,backend developer
JOB_LOCATION=India
GITHUB_USER=Ritabrata-Paul
PRE_SCORE_MIN=30           # skip jobs below this relevance before spending Claude tokens
TARGET_SCORE=90            # desired ATS match
MAX_TAILOR=10              # max Claude tailorings per run

# ── Email notify (optional) ──
SMTP_USER=                 # Gmail address
SMTP_PASS=                 # Gmail App Password (not your login password), spaces removed
NOTIFY_TO=                 # defaults to SMTP_USER

# ── MongoDB Atlas (applications dashboard) ──
MONGODB_USER=              # Atlas DB user
MONGODB_PASS=              # Atlas DB password (raw — code URL-encodes it)
MONGODB_CLUSTER=           # e.g. cluster0.ab12cd.mongodb.net  (from Atlas > Connect > Drivers)
MONGODB_DB=portfolio

# ── Private dashboard login (email + password) ──
ADMIN_EMAIL=              # your login email
ADMIN_PASSWORD_HASH=      # scrypt salt:hash — generate with the node -e snippet in README
SESSION_TTL_HOURS=12      # how long a login session lasts
